generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  createdAt   DateTime  @default(now()) @map("created_at")
  pembicaraId Int       @map("pembicara_id")
  tanggal     DateTime
  categoryId  Int       @map("category_id")
  category    Category  @relation(fields: [categoryId], references: [id])
  pembicara   Pembicara @relation(fields: [pembicaraId], references: [id])

  @@map("events")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  events    Event[]

  @@map("categories")
}

model Pembicara {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  events    Event[]

  @@map("speakersnp")
}
